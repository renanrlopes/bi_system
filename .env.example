# Copie para .env e preencha.
# Nunca comite o arquivo .env com segredos reais.

# --------------------
# App
# --------------------
# Gere uma chave forte (min. 32 caracteres).
FLASK_SECRET_KEY=troque-esta-chave-em-producao

# true apenas localmente para debug.
FLASK_DEBUG=false

# Porta local (em plataformas como Render o PORT vem do ambiente).
PORT=5000

# --------------------
# Sessao/cookies
# --------------------
# Em produção HTTPS: true
# Em localhost HTTP: false
SESSION_COOKIE_SECURE=true

# --------------------
# Banco (SQLite local)
# --------------------
# Produção grátis (Render + Supabase): use DATABASE_URL.
# Exemplo: postgresql://user:password@host:5432/postgres
DATABASE_URL=

# Diretório dos JSONs e logs
DATA_DIR=data

# Arquivo do banco SQLite
DB_PATH=data/app.db

# --------------------
# Mercado Livre API (OAuth)
# --------------------
# App credentials (Mercado Livre Developers)
ML_CLIENT_ID=
ML_CLIENT_SECRET=

# Tokens OAuth
ML_ACCESS_TOKEN=
ML_REFRESH_TOKEN=

# ID do vendedor (obtido em /users/me)
ML_SELLER_ID=

# --------------------
# Sincronizacao automatica
# --------------------
# 0 desativa job automatico. Ex.: 30 = a cada 30 minutos.
ML_AUTO_SYNC_MINUTES=30
